{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build %PROJECT_NAME%",
            "type": "fpc",
            "file": "${workspaceFolder}\\%PROJECT_NAME%.lpr",
            "cwd": "${workspaceFolder}",
            "buildOption": {
                "syntaxMode": "ObjFPC",
                "outputFile": "${workspaceFolder}\\%PROJECT_NAME%.exe"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$fpc"
        }
    ]
}
